# ─── AI: OpenAI GPT-4 Vision (room analysis + layout suggestions) ───
# Without this, /api/analyze returns a realistic mock analysis.
OPENAI_API_KEY=

# ─── AI: Replicate Stable Diffusion / SDXL (redesign previews) ───
# Without this, /api/redesign returns a styled placeholder preview.
REPLICATE_API_TOKEN=

# ─── Media: Cloudinary (image hosting) ───
# Without these, /api/upload falls back to returning the data URL directly.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public app URL (used in metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
